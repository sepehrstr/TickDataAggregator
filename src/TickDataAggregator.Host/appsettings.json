{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Enrichers.Thread" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "Npgsql": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithThreadId" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/tick-aggregator-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Pipeline": {
    "ChannelCapacity": 1000,
    "BatchSize": 50,
    "BatchFlushIntervalMs": 500,
    "DeduplicationWindowSeconds": 10
  },
  "ExchangeConnections": {
    "Endpoints": [
      {
        "Name": "ExchangeA",
        "Url": "ws://localhost:5100/exchange-a",
        "Enabled": true,
        "ReconnectBaseDelayMs": 1000,
        "ReconnectMaxDelayMs": 30000
      },
      {
        "Name": "ExchangeB",
        "Url": "ws://localhost:5100/exchange-b",
        "Enabled": true,
        "ReconnectBaseDelayMs": 1000,
        "ReconnectMaxDelayMs": 30000
      },
      {
        "Name": "ExchangeC",
        "Url": "ws://localhost:5100/exchange-c",
        "Enabled": true,
        "ReconnectBaseDelayMs": 1000,
        "ReconnectMaxDelayMs": 30000
      },
      {
        "Name": "Binance",
        "Kind": "Binance",
        "Url": "wss://stream.binance.com:9443/ws/btcusdt@trade",
        "Enabled": false,
        "ReconnectBaseDelayMs": 1000,
        "ReconnectMaxDelayMs": 30000
      },
      {
        "Name": "Coinbase",
        "Kind": "Coinbase",
        "Url": "wss://advanced-trade-ws.coinbase.com",
        "Enabled": false,
        "ReconnectBaseDelayMs": 1000,
        "ReconnectMaxDelayMs": 30000
      }
    ]
  },
  "Database": {
    "ConnectionString": "Host=localhost;Port=5432;Database=tickdata;Username=postgres;Password=postgres"
  }
}
